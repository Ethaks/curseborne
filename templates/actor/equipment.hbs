{{! Inline template for individual equipment item }}
{{#*inline "equipment"}}
	<li
		class='item equipment flexrow {{ifThen (not system.equipped) "unequipped" ""}}'
		data-item-id="{{item.id}}"
		data-flip-id="{{@root.rootId}}-{{item.id}}"
	>
		{{! Item Name and Image }}
		<div class="item-name flexrow" data-tooltip="{{tooltip}}">
			<div class="item-image">
				<img src="{{item.img}}" alt="{{item.name}}" width="24" height="24">
			</div>
			<span>{{item.name}}</span>
		</div>

		{{! Armor or Enhancement Bonus }}
		<div class="bonus">
			{{! Armor }}
			{{#if (eq system.type "armor")}}
				<div
					class="armor"
					data-tooltip
					aria-label="{{localize 'CURSEBORNE.Item.Equipment.FIELDS.armor.label' }}"
				>
					<i class="fa-solid fa-shield"></i>
					<span class="armor-value">{{system.armor}}</span>
				</div>
			{{/if}}

			{{! Enhancement}}
			{{#if (not (eq system.type "armor"))}}
				<div
					class="enhancement"
					data-tooltip
					aria-label="{{localize 'CURSEBORNE.Item.Equipment.FIELDS.enhancement.label' }}"
				>
					<i class="fa-solid fa-plus"></i>
					<span class="enhancement-value">{{system.enhancement}}</span>
				</div>
			{{/if}}
		</div>

		{{! Controls }}
		<div class="item-controls">
			{{! Equipped Toggle }}
			<button
				class="unbutton item-control"
				data-tooltip
				aria-label="{{localize 'CURSEBORNE.Item.Equipment.FIELDS.equipped.label'}}"
				data-action="toggleEquipped"
			>
				<i class='fa-solid fa-toggle-{{ifThen system.equipped "on" "off"}}'></i>
			</button>

			{{#if @root.editable}}
				<a class="item-control item-delete" data-action="deleteDoc">
					<i class="fa-solid fa-trash"></i>
				</a>
			{{/if}}
			<a class="item-control" data-action="contextMenu" data-tooltip="CURSEBORNE.ContextMenu">
				<i class="fa-solid fa-ellipsis-v"></i>
			</a>
		</div>
	</li>
{{/inline}}

<section class="tab {{tab.id}} {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">
	{{! Equipment Search Bar }}
	<search class="flexrow" data-search="equipment">
		<button
			type="button"
			class="inline-control toggle-search-mode icon"
			data-action="toggleSearchMode"
		>
		</button>

		{{! Search Input }}
		<input
			type="search"
			name="equipment-search"
			class="equipment-search"
			placeholder="{{localize 'Search'}}"
		>
	</search>

	{{! Equipment Sections }}
	{{#each equipment.sections}}
		{{#if items.length}}
			<section class="items-section equipment type boxed-list">
				{{! Section Header }}
				<div class="items-header header flexrow">
					<h3 class="item-name">{{localize label}}</h3>

					<span
						class="bonus"
						data-tooltip
						aria-label="{{localize 'CURSEBORNE.Item.Equipment.ArmorEnhancementHeader'}}"
					>
						<sup>
							<i class="fa-solid fa-shield"></i>
						</sup>
						/
						<sub>
							<i class="fa-solid fa-plus"></i>
						</sub>
					</span>

					<div class="item-controls"></div>
				</div>

				<ol class="items-list unlist">
					{{#each items}}
						{{~> equipment item=this}}
					{{/each}}
				</ol>
			</section>
		{{/if}}
	{{/each}}

	{{#if editable}}
		<button type="button" class="item-create" data-action="createDoc" data-type="equipment">
			<i class="fa-solid fa-plus"></i>
		</button>
	{{/if}}
</section>
