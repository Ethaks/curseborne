<section class="tab standard-form {{tab.cssClass}}" data-group="primary" data-tab="{{tab.id}}">
	{{curse-formGroup systemFields.type formGroupOptions localize=true}}

	{{! Armor Details }}
	{{#if (eq system.type "armor")}}
		<fieldset class="armor">
			<legend>
				<span>{{localize "CURSEBORNE.Item.Equipment.FIELDS.type.Armor"}}</span>
			</legend>
			{{curse-formGroup systemFields.armor formGroupOptions}}
		</fieldset>
	{{/if}}

	{{#if (not (eq system.type "armor"))}}
		{{curse-formGroup systemFields.enhancement formGroupOptions}}
	{{/if}}

	{{! Equipped State, if the item is embedded in an actor}}
	{{#if item.parent}}
		{{curse-formGroup systemFields.equipped formGroupOptions localize=true}}
	{{/if}}
</section>
